{
  "name": "playwright-resilient-agent",
  "version": "1.0.0",
  "description": "Reliable & Resilient UI + API Automation Agent using Playwright + TypeScript",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=chromium",
    "test:api": "playwright test tests/api/**",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "generate": "ts-node scripts/generate-test.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "ci": "playwright test --reporter=github,html"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5",
    "eslint": "^9.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "ts-node": "^10.9.2"
  }
}
